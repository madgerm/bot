{
  "system": {
    "name": "bot-runtime",
    "host": "127.0.0.1",
    "auth": {
      "enabled": false,
      "users": []
    },
    "communication": {
      "mode": "direct",
      "inbox_base": "teams/{team_id}/agents/{agent_id}/inbox",
      "multi_machine": {
        "enabled": false,
        "shared_inbox_base": null
      }
    },
    "polling": {
      "interval_seconds": 5,
      "inbox_watch_seconds": 0.5,
      "worker_mode": "process"
    },
    "llm": {
      "enabled": false,
      "provider": "litellm",
      "api_base": "http://127.0.0.1:4000",
      "secret_ref": "LITELLM_API_KEY",
      "max_retries": 3,
      "retry_backoff_seconds": 1.0,
      "timeout_seconds": 120
    }
  },
  "qdrant_global": {
    "enabled": false,
    "url": "http://127.0.0.1:6333",
    "secret_ref": "QDRANT_API_KEY",
    "embedding": {
      "provider": "hash",
      "vector_size": 384
    },
    "timeout_seconds": 30,
    "reindex": {
      "enabled": false,
      "interval_seconds": 3600,
      "watch_workspace": true,
      "watch_interval_seconds": 30,
      "debounce_seconds": 90,
      "include_crawl": true
    }
  },
  "playwright_global": {
    "mode": "local",
    "ws_endpoints": [],
    "headless": true,
    "timeout_seconds": 60
  },
  "webhooks_global": {
    "enabled": true,
    "secret_ref": "BOT_WEBHOOK_SECRET",
    "path_prefix": "/api/v1/webhooks"
  },
  "media_global": {
    "vision": {
      "source": "global",
      "provider": "litellm",
      "model": "gpt-4o-mini",
      "secret_ref": "LITELLM_API_KEY"
    },
    "stt": {
      "source": "global",
      "endpoint": "http://127.0.0.1:9100/transcribe",
      "secret_ref": null
    },
    "tts": {
      "source": "global",
      "endpoint": "http://127.0.0.1:9101/synthesize",
      "voice_id": "de_DE_neural"
    },
    "image_generation": {
      "source": "global",
      "type": "webhook",
      "url": "http://127.0.0.1:9200/generate",
      "default_aspect": "16:9",
      "timeout_seconds": 180
    }
  },
  "deployment": {
    "topology": "single_user",
    "team_agent_scope": "system",
    "team_user_prefix": "team_",
    "systemd_template": "bot-team@.service"
  }
}
