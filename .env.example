# Bot — Umgebungsvariablen (Kopie nach .env und Werte setzen; .env nicht committen)

# Web-Panel (Pflicht in Produktion)
BOT_SESSION_SECRET=change-me-to-random-hex-64-chars
# CSRF für HTML-Formulare (Standard: an)
# BOT_WEB_CSRF=true
# Login-Rate-Limit: Versuche pro Fenster (Standard: 10 / 300s)
# BOT_LOGIN_RATE_LIMIT=10
# BOT_LOGIN_RATE_WINDOW=300

# Team-Runner Remote-API + LLM-Proxy (Panel ↔ VPS, gleicher Token möglich)
BOT_TEAM_API_TOKEN=
BOT_LLM_PROXY_TOKEN=
# Internet-Relay (bot relay serve) — Panel + Runner gleicher Raum/Token
BOT_RELAY_TOKEN=

# LLM (LiteLLM / OpenAI-kompatibel)
LITELLM_API_KEY=

# Webhooks (eingehend ins Panel)
BOT_WEBHOOK_SECRET=

# E-Mail (Team-spezifisch in teams/<id>/email.json referenziert)
FIRMA_IMAP_PASSWORD=
FIRMA_SMTP_PASSWORD=

# Qdrant (optional, wenn nicht in system.json)
# QDRANT_API_KEY=

# Playwright remote (optional)
# PLAYWRIGHT_WS_ENDPOINT=
